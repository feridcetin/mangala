<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 1) Glow ring (dış halka) -->
    <item>
        <shape android:shape="oval">
            <stroke
                android:width="2dp"
                android:color="#66FFC107" />
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>

    <!-- 2) Main body (iç yüzey) -->
    <item android:insetLeft="3dp" android:insetTop="3dp"
        android:insetRight="3dp" android:insetBottom="3dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="100dp"
                android:centerX="0.35"
                android:centerY="0.30"
                android:startColor="#FFF3E8"
                android:centerColor="#F4C7A3"
                android:endColor="#C98F67"/>

            <!-- iç highlight -->
            <stroke android:width="1dp" android:color="#55FFFFFF"/>
        </shape>
    </item>

    <!-- 3) Inner shadow (iç çukur hissi) -->
    <item android:insetLeft="6dp" android:insetTop="6dp"
        android:insetRight="6dp" android:insetBottom="6dp">
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="#22000000"/>
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>

</layer-list>