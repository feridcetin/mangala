<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base: mevcut side_nav_bar (koyu gradient) -->
    <item android:drawable="@drawable/side_nav_bar"/>

    <!-- Stronger top highlight -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#99FFFFFF"
                android:endColor="#10FFFFFF"/>
        </shape>
    </item>

    <!-- Overall lightening overlay (subtle white veil) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#22FFFFFF"/>
        </shape>
    </item>

</layer-list>